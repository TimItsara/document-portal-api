# ── Database ─────────────────────────────────────────────────────────────────
# Pooled connection string (used by Prisma at runtime)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# Direct connection string (used by Prisma for migrations)
DATABASE_URL_UNPOOLED="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random string used to sign JWT tokens
# Generate one: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
AUTH_SECRET="your-long-random-secret-here"

# ── Truuth API ────────────────────────────────────────────────────────────────
TRUUTH_API_KEY="your-truuth-api-key"
TRUUTH_API_SECRET="your-truuth-api-secret"

# ── CORS ──────────────────────────────────────────────────────────────────────
# Frontend origin allowed to call this API
# Development: http://localhost:5173
# Production:  https://your-frontend.vercel.app
FRONTEND_URL=http://localhost:5173
